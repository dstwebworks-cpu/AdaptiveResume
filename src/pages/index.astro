---
import Base from '../layouts/Base.astro';
// The product app (separate deploy) — set PUBLIC_APP_URL at build in production.
const appUrl = import.meta.env.PUBLIC_APP_URL ?? 'http://localhost:5173';
---
<Base
  title="AdaptiveResume — you've earned more than your resume shows"
  description="Upload your resume and we'll find the standards, tools, and credentials your work involved that you left off — then ask you to confirm each one. Nothing made up. No guaranteed outcomes. $49 base · $149 targeted build."
>
  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">You're not in this alone</p>
        <h1>You've earned <span class="hl">more</span> than your resume shows.</h1>
        <p class="tagline">You did the work. Now let's get it on paper — together. You approve every line, and we don't make anything up.</p>
        <p class="lede">
          Upload your resume and we'll dig in with you — finding the standards, tools, and training
          your work involved but you never thought to list. You confirm each one, in your words.
          Built to read cleanly for the screening bots <em>and</em> the humans.
        </p>
        <div class="cta-row">
          <a class="btn btn-amber btn-lg" href="#get-started">Upload your resume &amp; get started</a>
          <a class="btn btn-ghost btn-lg" href={appUrl + '/?demo'}>Try a sample review — no sign-up</a>
        </div>
        <ul class="pills">
          <li class="pill">✓ Nothing made up</li>
          <li class="pill">✓ ATS-readable</li>
          <li class="pill">✓ You approve every line</li>
        </ul>
      </div>

      <div class="hero-visual" aria-label="Example of skills we'd find on a resume">
        <div class="demo-card">
          <div class="demo-head"><span class="dot"></span> Here's what we'd find — you tell us what's yours</div>
          <ul>
            <li><span class="add">+ Trained and onboarded new hires</span> <span class="conf">yours?</span></li>
            <li><span class="add">+ Required safety &amp; compliance training (OSHA, HIPAA…)</span> <span class="conf">yours?</span></li>
            <li><span class="add">+ Standard operating procedures (SOPs) — wrote &amp; followed</span> <span class="conf">yours?</span></li>
            <li class="ask"><span>CPR / First Aid / AED — currently certified?</span> <span class="conf">we ask, you decide</span></li>
          </ul>
          <p class="covcap">A full review walks you through everything it finds — you confirm each line, in your own words.</p>
        </div>
        <p class="cap">Sample data — generic profile, no real employer shown.</p>
      </div>
    </div>
  </section>

  <!-- ===== GET STARTED (directly below the hero — the shortest path in) ===== -->
  <section id="get-started" class="section alt">
    <div class="container start">
      <p class="eyebrow">Get started</p>
      <h2>Let's see what you've been leaving off.</h2>
      <p class="lede">Create your account, upload your resume, and we'll dig in together — finding real things you've earned but never wrote down. You approve every line before anything lands.</p>

      <div class="start-cta">
        <a class="btn btn-amber btn-lg" href={appUrl}>Create an account — get started today</a>
        <p class="start-alt muted">Already have an account? <a href={appUrl + '/login'}>Sign in now</a></p>
      </div>

      <p class="reoffer muted">
        Want to see it first? <a href={appUrl + '/?demo'}>Try a sample review</a> or <a href="#demo">watch the 90-second walkthrough</a> — no upload, no account.
      </p>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section id="how-it-works" class="section alt">
    <div class="container">
      <p class="eyebrow">How it works</p>
      <h2>Three steps. You stay the author the whole way.</h2>
      <div class="grid cols-3 steps">
        <div class="card">
          <span class="step-n">1</span>
          <h3>Upload</h3>
          <p>Add up to three resumes (and, if you like, your LinkedIn profile PDF). Your data is a file you provide — we only ever use what you upload.</p>
        </div>
        <div class="card">
          <span class="step-n">2</span>
          <h3>Confirm</h3>
          <p>We'll show you skills and credentials common to work like yours and ask which ones are really you. Nothing lands on your resume until you say it's yours.</p>
        </div>
        <div class="card">
          <span class="step-n">3</span>
          <h3>Download</h3>
          <p>Get a clean, <a href="/guides/what-is-an-ats">ATS</a>-readable resume built only from what you confirmed — and see for yourself how the screening software reads it.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== DEMO / VIDEO ===== -->
  <section id="demo" class="section">
    <div class="container demo-grid">
      <div>
        <p class="eyebrow">See it work first</p>
        <h2>Watch a real run before you spend a dime.</h2>
        <p class="lede">A 90-second walkthrough on a sample profile — how we dig in together to find what someone left off, ask before anything goes on the page, and check it reads cleanly for the bots <em>and</em> the humans.</p>
        <a class="btn btn-primary" href="#get-started">Try it on your own resume →</a>
      </div>
      <div class="video-ph" role="img" aria-label="Product walkthrough video placeholder">
        <button class="play" aria-label="Play the 90-second walkthrough">▶</button>
        <span>[ 90-second walkthrough video — placeholder ]</span>
      </div>
    </div>
  </section>

  <!-- ===== FOR JOB SEEKERS ===== -->
  <section id="job-seekers" class="section alt">
    <div class="container jobs-grid">
      <div>
        <p class="eyebrow">For job seekers</p>
        <h2>The resume that finally reflects the work you did.</h2>
        <p class="lede">For career changers, military and government-to-private transitions, the trades, and specialists who do far more than their resume shows.</p>
        <ul class="ticks">
          <li>We'll find the skills and credentials you left off — you confirm each one, in your words</li>
          <li>Aiming at a specific role? We'll point your experience toward it (targeted build)</li>
          <li>Turns government, military, and trade terms into language the hiring side recognizes — <a href="#military">see a real translation</a></li>
          <li>See for yourself how the screening software reads your resume</li>
        </ul>
        <a class="btn btn-primary" href="#pricing">See pricing &amp; get started →</a>
      </div>
      <img src="/img/resume-doc.svg" width="480" height="320" alt="A resume with surfaced skills highlighted and a verification check" loading="lazy" />
    </div>
  </section>

  <!-- ===== HOW WE DIFFER (comparison) ===== -->
  <section id="compare" class="section alt">
    <div class="container">
      <p class="eyebrow">How we differ</p>
      <h2>How AdaptiveResume compares to other resume tools.</h2>
      <p class="lede" style="max-width:62ch">Most tools either make you do all the thinking, or do too much of it — and invent things along the way. Here's the honest difference, by category.</p>
      <div class="table-wrap">
        <table class="compare">
          <thead>
            <tr>
              <th>What matters</th>
              <th>Template builders</th>
              <th>AI generators</th>
              <th>Human writers</th>
              <th class="us">AdaptiveResume</th>
            </tr>
          </thead>
          <tbody>
            <tr><th>Works backwards from your real experience</th><td class="x">✗</td><td class="p">~</td><td class="c">✓</td><td class="us c">✓</td></tr>
            <tr><th>Finds what you left off — and makes you confirm each item</th><td class="x">✗</td><td class="p">~</td><td class="c">✓</td><td class="us c">✓</td></tr>
            <tr><th>Won't make anything up</th><td class="c">✓</td><td class="x">✗</td><td class="c">✓</td><td class="us c">✓</td></tr>
            <tr><th>You approve every line</th><td class="c">✓</td><td class="x">✗</td><td class="p">~</td><td class="us c">✓</td></tr>
            <tr><th>Shows what the ATS actually extracts</th><td class="x">✗</td><td class="p">~</td><td class="x">✗</td><td class="us c">✓</td></tr>
            <tr><th>Translates across fields (military / gov / industry)</th><td class="x">✗</td><td class="p">~</td><td class="c">✓</td><td class="us c">✓</td></tr>
            <tr><th>Typical cost</th><td>$0–$40<br /><span class="sub">often subscription</span></td><td>$10–$50+<br /><span class="sub">often subscription</span></td><td>$120–$700+<br /><span class="sub">one-time</span></td><td class="us">$49–$149<br /><span class="sub">one-time</span></td></tr>
          </tbody>
        </table>
      </div>
      <p class="muted small" style="margin-top:12px">Cost ranges are typical figures for each category, for comparison — not quotes from specific companies. "~" means it depends on the tool. We never promise an outcome.</p>
    </div>
  </section>

  <!-- ===== THE HONEST CHATBOT QUESTION ===== -->
  <section id="vs-chat" class="section">
    <div class="container" style="max-width:820px">
      <p class="eyebrow">The honest question</p>
      <h2>"Can't I just ask a chatbot to do this?"</h2>
      <p class="lede">
        You can ask — and you'll get something plausible-looking back. The difference isn't the asking.
        It's the <b>verification</b>.
      </p>
      <ul class="ticks">
        <li><b>Chat output is unverified.</b> It reads well, but nothing checks it — you'd have to audit every line yourself, and honestly, nobody does that in a chat window.</li>
        <li><b>Here, every line is enforced.</b> Our system traces each line back to something you confirmed, asks before it ever lists a credential, and flags anything it can't source — before you ever see the resume.</li>
        <li><b>You stay the author.</b> One finding at a time, your original words quoted back, edit or skip anything — so the resume you send is one you can defend in the interview.</li>
      </ul>
      <p><a href={appUrl + '/?demo'}>Watch the verification work on a sample review →</a></p>

      <!-- ===== THE TIME MATH (toggle: vs writer / vs DIY chat) ===== -->
      <div class="timemath">
        <h3>The time math</h3>
        <p class="muted">It feels like working with someone — because you are. One finding at a time, together, with no appointment to book. Compare your path:</p>
        <div class="tm-tabs">
          <button class="tm-tab active" data-tm="writer">vs. a resume writer</button>
          <button class="tm-tab" data-tm="diy">vs. DIY with a chatbot</button>
        </div>
        <div class="tm-panel" data-tm="writer">
          <div class="tm-col">
            <h4>A professional writing service</h4>
            <ul>
              <li>Book, pay, fill out their questionnaire — day one</li>
              <li>First draft arrives in 3–7 <em>business days</em> (typical advertised turnarounds, 2026)</li>
              <li>Revision rounds: roughly another week — if they honor them</li>
              <li><b>Calendar time: one to two weeks of waiting</b></li>
            </ul>
          </div>
          <div class="tm-col us">
            <h4>Here</h4>
            <ul>
              <li>Upload — your free scan appears in seconds</li>
              <li>Findings start streaming moments after your review begins</li>
              <li>You review one finding at a time, at your pace — most people finish in one sitting, and everything saves if life interrupts</li>
              <li><b>Calendar time: today</b> — the longest you wait on us is measured in seconds, and there's a live clock on screen whenever we're working</li>
            </ul>
          </div>
        </div>
        <div class="tm-panel hide" data-tm="diy">
          <div class="tm-col">
            <h4>DIY with a chatbot</h4>
            <ul>
              <li>Rounds of prompting and re-prompting to get something usable</li>
              <li>Then the step almost nobody does: auditing every line yourself, because nothing else checks it</li>
              <li>Then wrestling the text into a clean, screening-software-safe file</li>
              <li><b>Your active work: an evening or more — with the verification burden entirely on you</b></li>
            </ul>
          </div>
          <div class="tm-col us">
            <h4>Here</h4>
            <ul>
              <li>The digging, the checking, and the formatting are the product — verification is enforced by the system, not left to your discipline</li>
              <li>You spend your time on the one thing only you can do: confirming what's true</li>
              <li>Finished, checked, formatted files — Word and PDF — at the end of the same sitting</li>
              <li><b>Your active work: one focused session, guided the whole way</b></li>
            </ul>
          </div>
        </div>
        <p class="muted small">Turnaround comparisons reflect typical advertised timelines of major resume-writing services (2026). We never promise a fixed duration — you'll always see a live clock while we work.</p>
      </div>
    </div>
  </section>

  <!-- ===== MILITARY / GOVERNMENT TRANSLATION PROOF ===== -->
  <section id="military" class="section alt">
    <div class="container" style="max-width:820px">
      <p class="eyebrow">Military &amp; government transitions</p>
      <h2>Your record is strong. Its language is the problem.</h2>
      <p class="lede">
        Civilian screening software has never heard of an AMAL block, an NCOER, or a property book.
        We translate what you actually did into the words the hiring side searches for — and you approve every line.
      </p>
      <div class="beforeafter">
        <div class="ba-row"><span class="ba-tag">Your resume says</span>
          <p>"Maintained AMAL blocks and surgical instrument sets"</p></div>
        <div class="ba-row after"><span class="ba-tag">Translated — same truth, their words</span>
          <p>"Performed sterile processing end to end — decontamination, assembly, sterilization, and quality inspection of surgical instrument sets and case carts — to hospital SPD standards."</p></div>
      </div>
      <p class="muted small">Sample translation — generic profile, no real service member shown.</p>
      <p><a href={appUrl + '/?demo=military'}>See the full military sample review — no sign-up →</a></p>
    </div>
  </section>

  <!-- ===== PRICING (consumer only) ===== -->
  <section id="pricing" class="section">
    <div class="container">
      <p class="eyebrow">Pricing</p>
      <h2>One payment. No subscription. Nothing to cancel.</h2>
      <div class="grid cols-2 pricing">
        <div class="card price">
          <h3>Base build</h3>
          <p class="amount">$49<span>one-time</span></p>
          <p class="muted">Your one resume, made complete — everything you've earned, finally on paper.</p>
          <ul class="ticks">
            <li>Bring up to three old resumes (even the messy ones) plus your LinkedIn profile PDF</li>
            <li>We'll dig through them together and find what you left off — you confirm what's yours</li>
            <li>Reads cleanly for the screening software, and for the person after it</li>
            <li>We run the format checks screening software cares about — and show you each one</li>
          </ul>
          <a class="btn btn-primary" href="#get-started">Get started</a>
        </div>

        <div class="card price featured">
          <span class="tag-premium">For a specific role</span>
          <h3>Targeted build</h3>
          <p class="amount">$149<span>one-time</span></p>
          <p class="muted">Everything in base — plus we'll aim your resume at the one role you're going for, in language that side recognizes.</p>
          <ul class="ticks">
            <li>We'll translate your experience into the new field's language — government, military, and trade terms included</li>
            <li>An honest read on where you match the role, and where you don't</li>
            <li>25 interview questions for that exact role — what they'll ask, why, and how to answer from your real experience</li>
          </ul>
          <a class="btn btn-premium" href="#get-started">Get started</a>
        </div>
      </div>
      <p class="muted finep">If your review genuinely finds nothing for you, we'll make it right — see the <a href="/terms">Terms</a> for the plain-language details.</p>
    </div>
  </section>

  <!-- ===== COMMERCIAL BANNER (links to dedicated page) ===== -->
  <section class="section tint">
    <div class="container banner">
      <img src="/img/office-desk.svg" width="480" height="320" alt="Two people talking across an office desk" loading="lazy" />
      <div>
        <p class="eyebrow">For organizations</p>
        <h2>Hiring, staffing, or placing people?</h2>
        <p class="lede">AdaptiveResume fills out every candidate's resume in bulk — with the same promise, nothing made up — for staffing agencies, outplacement firms, workforce boards, and veteran and reentry nonprofits.</p>
        <a class="btn btn-primary btn-lg" href="/business">Interested in commercial offerings for your organization? →</a>
      </div>
    </div>
  </section>

  <!-- ===== LEGAL NOTE ===== -->
  <section id="legal" class="section">
    <div class="container legalnote">
      <p class="muted">
        <b>How we work:</b> nothing made up · ATS-readable · real value added · your edits honored.
        Read the full <a href="/terms">Terms of Service</a>, <a href="/privacy">Privacy Policy</a>, and
        <a href="/disclaimer">Disclaimer</a>.
      </p>
    </div>
  </section>

  <style>
    /* hero — cool glow top-right, warm glow bottom-left for depth */
    .hero { padding: 58px 0 40px; background:
      radial-gradient(1100px 460px at 72% -12%, #d8e5fa, transparent 70%),
      radial-gradient(760px 380px at 4% 112%, #fdf0dc, transparent 62%),
      var(--bg); }
    .hero-grid { display: grid; gap: 36px; align-items: center; }
    @media (min-width: 960px) { .hero-grid { grid-template-columns: 1.05fr 0.95fr; padding-top: 18px; } }
    .tagline { font-size: clamp(1.1rem, 2vw, 1.4rem); font-weight: 700; color: var(--ink); margin: 0 0 12px; }
    .cta-row { display: flex; flex-wrap: wrap; gap: 12px; margin: 22px 0 18px; }
    .pills { display: flex; flex-wrap: wrap; gap: 10px; list-style: none; padding: 0; margin: 0; }

    .demo-card { background: linear-gradient(160deg, #16244a, #0b1226); color: #e6ecfb; border: 1px solid #2a3a6b; border-radius: var(--radius); padding: 18px 18px 14px; box-shadow: 0 18px 52px rgba(16,32,64,.28); }
    .demo-head { font-size: .82rem; letter-spacing: .04em; color: #9fb3e0; margin-bottom: 12px; display: flex; align-items: center; gap: 8px; }
    .demo-head .dot { width: 9px; height: 9px; border-radius: 50%; background: #4ade80; display: inline-block; }
    .demo-card ul { list-style: none; margin: 0 0 16px; padding: 0; }
    .demo-card li { display: flex; justify-content: space-between; gap: 12px; padding: 8px 0; border-bottom: 1px solid rgba(255,255,255,.08); font-size: .92rem; }
    .demo-card .add { color: #c9f7d8; }
    .demo-card .conf { color: #9fb3e0; font-size: .8rem; white-space: nowrap; }
    .demo-card li.ask span:first-child { color: #ffe1a8; }
    .covcap { font-size: .8rem; color: #9fb3e0; margin: 4px 0 0; }
    .cap { font-size: .78rem; color: var(--muted); margin-top: 10px; text-align: center; }

    /* steps */
    .steps .card { position: relative; padding-top: 30px; }
    .steps .card:hover { box-shadow: var(--shadow-lg); }
    .step-n { position: absolute; top: -16px; left: 22px; width: 34px; height: 34px; display: grid; place-items: center; border-radius: 9px; background: linear-gradient(135deg, var(--accent-strong), #d97706); color: #16202b; font-weight: 800; box-shadow: 0 4px 12px rgba(217,119,6,.3); }

    /* demo + jobs split */
    .demo-grid, .jobs-grid { display: grid; gap: 30px; align-items: center; }
    @media (min-width: 880px) { .demo-grid, .jobs-grid { grid-template-columns: 1fr 1fr; } }
    .jobs-grid img { border-radius: var(--radius); box-shadow: var(--shadow); width: 100%; height: auto; }
    .video-ph { position: relative; aspect-ratio: 16/9; border-radius: var(--radius); background: linear-gradient(135deg,#1b2740,#0f1830); color: #cdd7ef; display: grid; place-items: center; text-align: center; padding: 16px; box-shadow: var(--shadow-lg); }
    .video-ph span { font-size: .85rem; opacity: .8; position: absolute; bottom: 14px; }
    .video-ph .play { width: 64px; height: 64px; border-radius: 50%; border: none; background: linear-gradient(180deg, #fbb043, var(--accent-strong)); color: #16202b; font-size: 1.3rem; cursor: pointer; box-shadow: 0 8px 24px rgba(217,119,6,.4); transition: transform .1s; }
    .video-ph .play:hover { transform: scale(1.06); }

    .ticks { list-style: none; padding: 0; margin: 14px 0 18px; }
    .ticks li { padding-left: 26px; position: relative; margin-bottom: 9px; color: var(--ink-soft); }
    .ticks li::before { content: "✓"; position: absolute; left: 0; color: var(--true); font-weight: 800; }

    /* pricing */
    .pricing .price { display: flex; flex-direction: column; }
    .price.featured { border-color: #cbb4f0; box-shadow: 0 0 0 3px #ece2fb, var(--shadow-lg); position: relative; }
    .amount { font-size: 2.4rem; font-weight: 800; letter-spacing: -0.02em; margin: 6px 0 4px; }
    .amount span { font-size: .9rem; font-weight: 600; color: var(--muted); margin-left: 8px; letter-spacing: 0; }
    .price .btn { margin-top: auto; align-self: flex-start; }
    .finep { text-align: center; margin-top: 24px; font-size: .9rem; }

    /* comparison table (scrolls horizontally on small screens) */
    .table-wrap { overflow-x: auto; margin-top: 18px; -webkit-overflow-scrolling: touch; border-radius: var(--radius); }
    .compare { width: 100%; min-width: 720px; border-collapse: collapse; background: var(--card); }
    .compare th, .compare td { padding: 14px 16px; text-align: center; border-bottom: 1px solid var(--line); font-size: .95rem; vertical-align: middle; }
    .compare thead th { background: var(--surface); font-weight: 700; color: var(--ink); }
    .compare tbody th { text-align: left; font-weight: 600; color: var(--ink-soft); }
    .compare .us { background: var(--primary-bg); }
    .compare thead th.us { color: var(--primary); }
    .compare .c { color: var(--true); font-weight: 800; font-size: 1.05rem; }
    .compare .x { color: #b42318; font-weight: 800; font-size: 1.05rem; }
    .compare .p { color: var(--muted); font-weight: 800; }
    .compare .sub { font-size: .76rem; color: var(--muted); font-weight: 400; }
    .small { font-size: .85rem; }

    /* commercial banner */
    .banner { display: grid; gap: 28px; align-items: center; }
    @media (min-width: 880px) { .banner { grid-template-columns: 0.9fr 1.1fr; } }
    .banner img { border-radius: var(--radius); box-shadow: var(--shadow); width: 100%; height: auto; }

    /* get started */
    .start-cta { margin: 20px 0 6px; }
    .start-alt { margin-top: 12px; font-size: .95rem; }
    .start-alt a { font-weight: 700; }
    .start { max-width: 720px; text-align: center; }
    .start .lede { margin-left: auto; margin-right: auto; max-width: 56ch; }
    .dropzone { display: block; cursor: pointer; border: 2px dashed #9fb0c4; border-radius: var(--radius); background: var(--card); padding: 34px 20px; margin: 12px 0 14px; transition: border-color .15s, background .15s, box-shadow .15s; }
    .dropzone:hover { border-color: var(--accent-strong); background: #fffdf8; box-shadow: 0 0 0 4px var(--accent-bg); }
    .dropzone input { position: absolute; width: 1px; height: 1px; opacity: 0; }
    .dz-ico { display: block; font-size: 1.8rem; color: var(--accent); }
    .dz-main { display: block; font-weight: 700; font-size: 1.1rem; margin: 6px 0 2px; }
    .dz-sub { display: block; font-size: .9rem; }
    .reoffer { font-size: .95rem; }

    /* time math */
    .timemath { margin-top: 34px; }
    .timemath h3 { font-size: 1.3rem; margin: 0 0 6px; }
    .tm-tabs { display: flex; gap: 8px; margin: 14px 0; }
    .tm-tab { font: inherit; font-size: .9rem; font-weight: 700; padding: 8px 16px; border-radius: 999px; border: 1.5px solid var(--line); background: var(--card); color: var(--ink); cursor: pointer; }
    .tm-tab.active { background: var(--primary); border-color: var(--primary); color: #fff; }
    .tm-panel { display: grid; gap: 14px; }
    @media (min-width: 760px) { .tm-panel { grid-template-columns: 1fr 1fr; } }
    .tm-panel.hide { display: none; }
    .tm-col { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 16px 18px; }
    .tm-col.us { border-color: #7fb08a; background: #f3faf4; }
    .tm-col h4 { margin: 0 0 8px; font-size: 1rem; }
    .tm-col ul { margin: 0; padding-left: 18px; }
    .tm-col li { margin-bottom: 8px; color: var(--ink-soft); font-size: .95rem; }

    /* military before/after */
    .beforeafter { display: grid; gap: 12px; margin: 18px 0 10px; }
    .ba-row { background: var(--card); border: 1px solid var(--line); border-radius: var(--radius); padding: 14px 18px; }
    .ba-row.after { border-color: #7fb08a; background: #f3faf4; }
    .ba-tag { display: block; font-size: .78rem; font-weight: 700; letter-spacing: .04em; text-transform: uppercase; color: var(--muted); margin-bottom: 4px; }
    .ba-row.after .ba-tag { color: #2f7a45; }
    .ba-row p { margin: 0; font-size: 1rem; }

    .legalnote { text-align: center; }
    .legalnote p { max-width: 80ch; margin: 0 auto; font-size: .9rem; }
  </style>
  <script>
    // Time-math toggle (vs writer / vs DIY chat)
    document.querySelectorAll('.tm-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        const key = tab.getAttribute('data-tm');
        document.querySelectorAll('.tm-tab').forEach((t) => t.classList.toggle('active', t === tab));
        document.querySelectorAll('.tm-panel').forEach((p) => p.classList.toggle('hide', p.getAttribute('data-tm') !== key));
      });
    });
  </script>
</Base>
