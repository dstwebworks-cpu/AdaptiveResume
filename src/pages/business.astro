---
import Base from '../layouts/Base.astro';

const buyers = [
  'Staffing & recruiting agencies',
  'Outplacement firms',
  'Workforce boards / American Job Centers',
  'Veteran-transition & reentry nonprofits',
  'Community-college career offices',
  'Government workforce programs',
];
const steps = [
  { n: '1', h: 'Send us your batch', p: 'A batch of resume files or a CSV of candidates — ten or a full roster. During your pilot we handle intake for you under a signed data-processing agreement, over a secure channel; self-serve bulk upload is in active build. No per-seat setup fee.' },
  { n: '2', h: 'We fill in the gaps', p: 'Working backwards from each person\'s experience, we find the skills, standards, and training their role really involved — across a wide range of occupations.' },
  { n: '3', h: 'Your team reviews', p: 'Per-candidate results; low-confidence items and anything credential-like are held for your review, never claimed on their own. You sign off on what goes out under your name.' },
  { n: '4', h: 'Export', p: 'Per-candidate and org-level reports, plus ATS-clean resumes where you supplied the file — export as PDF, DOCX, or CSV/JSON for your ATS.' },
];
---
<Base
  title="AdaptiveResume for organizations — bulk candidate resume enrichment"
  description="Per-enriched-candidate resume enrichment for staffing agencies, outplacement firms, workforce boards, and veteran/reentry programs. Bulk processing, monthly volume tiers, and a simple promise — nothing made up. Request a quote."
>
  <!-- HERO -->
  <section class="hero">
    <div class="container hero-grid">
      <div>
        <p class="eyebrow">For organizations</p>
        <h1>Enrich every candidate's qualifications — at scale.</h1>
        <p class="lede">Your people earned qualifications they never put on paper. Send us your candidates; we find the standards, certs, tools, and training each role really involved — and flag anything credential-like for <b>your reviewer's</b> sign-off, so nothing is made up. You pay per enriched candidate.</p>
        <div class="cta-row">
          <a class="btn btn-amber btn-lg" href="#quote">Request a quote</a>
          <a class="btn btn-ghost btn-lg" href="#how-bulk">See how it works</a>
        </div>
        <p class="muted small">The same tool that powers our consumer product, configured for organizations.</p>
      </div>
      <img src="/img/office-desk.svg" width="480" height="320" alt="Two people talking across an office desk" />
    </div>
  </section>

  <!-- WHO IT'S FOR -->
  <section class="section alt">
    <div class="container">
      <p class="eyebrow">Who it's for</p>
      <h2>Built for the people who place people.</h2>
      <ul class="chips">
        {buyers.map((b) => <li class="chip">{b}</li>)}
      </ul>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="section" id="how-bulk">
    <div class="container">
      <p class="eyebrow">How it works (bulk)</p>
      <h2>From roster to enriched candidates in four steps.</h2>
      <div class="grid cols-2 steps">
        {steps.map((s) => (
          <div class="card"><span class="step-n">{s.n}</span><h3>{s.h}</h3><p>{s.p}</p></div>
        ))}
      </div>

      <p class="eyebrow" style="margin-top:36px">What you get depends on what you send</p>
      <div class="grid cols-2">
        <div class="card"><h3>Send a CSV</h3><p class="muted">Name, role, and employer per candidate. You get a per-candidate <b>qualification report</b> — the skills, standards, and training that role involves, in claimable language, plus a draft skills block. It is not a finished resume — a CSV has no work history, dates, or accomplishments to build one from.</p></div>
        <div class="card"><h3>Send resume files</h3><p class="muted">Each candidate's existing resume. We build a <b>full ATS-clean resume</b> from their real history, filled out with the qualifications they left off. Anything credential-like is flagged for sign-off — never made up.</p></div>
      </div>
    </div>
  </section>

  <!-- INTEGRITY / FEATURES -->
  <section class="section alt">
    <div class="container">
      <p class="eyebrow">Why it beats the manual way</p>
      <h2>Consistent, fatigue-free, and honest at scale.</h2>
      <div class="grid cols-3">
        <div class="card"><h3>Integrity at scale</h3><p>We never put a credential on a resume on our own. Anything that looks like a formal certification goes to your reviewer's queue to confirm first — nothing made up.</p></div>
        <div class="card"><h3>Finds what's implied</h3><p>The standards and training a role really involves (IATF, OSHA/LOTO, CLIA, NEC, MOS→civilian translation) that generic resume tools never name.</p></div>
        <div class="card"><h3>Honest build status</h3><p>Today: your reviewers work every candidate in our review queue, and we handle batch intake for you under a data-processing agreement. In active build: self-serve bulk upload with an itemized intake manifest. On the roadmap: API/webhook delivery into your own ATS. We will always tell you which is which.</p></div>
      </div>
    </div>
  </section>

  <!-- DIFFERENTIATOR -->
  <section class="section">
    <div class="container">
      <p class="eyebrow">How we compare</p>
      <h2>What you're choosing between — and why this wins.</h2>
      <p class="lede" style="max-width:64ch">The alternatives are either too slow to scale, too loose to trust, or too expensive per head. Here's the honest comparison.</p>
      <div class="table-wrap">
        <table class="compare">
          <thead>
            <tr>
              <th>What matters at scale</th>
              <th>In-house, by hand</th>
              <th>Generic AI bulk tools</th>
              <th>Human outplacement service</th>
              <th class="us">AdaptiveResume</th>
            </tr>
          </thead>
          <tbody>
            <tr><th>Scales to hundreds or thousands, fast</th><td class="x">✗</td><td class="c">✓</td><td class="p">~</td><td class="us c">✓</td></tr>
            <tr><th>Consistent quality across staff &amp; candidates</th><td class="x">✗</td><td class="p">~</td><td class="p">~</td><td class="us c">✓</td></tr>
            <tr><th>Never makes a credential up</th><td class="c">✓</td><td class="x">✗</td><td class="c">✓</td><td class="us c">✓</td></tr>
            <tr><th>Low-confidence flagged for YOUR reviewer</th><td class="p">~</td><td class="x">✗</td><td class="p">~</td><td class="us c">✓</td></tr>
            <tr><th>Finds skills candidates left off</th><td class="p">~</td><td class="x">✗</td><td class="c">✓</td><td class="us c">✓</td></tr>
            <tr><th>Bulk processing + structured export</th><td class="x">✗</td><td class="p">~</td><td class="x">✗</td><td class="us c">✓</td></tr>
            <tr><th>Typical cost</th><td>staff hours<br /><span class="sub">doesn't scale</span></td><td>low / per seat<br /><span class="sub">accuracy risk</span></td><td>$275–$10k+<br /><span class="sub">per employee</span></td><td class="us">per enriched candidate<br /><span class="sub">volume tiers · by quote</span></td></tr>
          </tbody>
        </table>
      </div>
      <p class="muted small" style="margin-top:12px">Cost figures are typical category ranges for comparison, not quotes from specific providers. "~" means it depends on the provider/process.</p>

      <div class="grid cols-2" style="margin-top:34px">
        <div class="card"><h3>The manual way</h3><p class="muted">Each recruiter or coach edits each resume by hand. Quality swings with whoever touched it, credentials can go out unchecked under deadline pressure, and it simply doesn't scale past a handful a day.</p></div>
        <div class="card" style="border-color:#cfe0fb;background:var(--primary-bg)"><h3>With AdaptiveResume</h3><p>Send your batch → consistent enrichment finds real skills → low-confidence items wait for <b>your</b> reviewer → export ATS-clean resumes + a per-candidate review audit report. Your team spends its time reviewing, not retyping — and nothing is made up.</p></div>
      </div>
    </div>
  </section>

  <!-- PRICING: model + quote -->
  <section id="quote" class="section tint">
    <div class="container quote-grid">
      <div>
        <p class="eyebrow">Pricing</p>
        <h2>Priced per enriched candidate, by volume.</h2>
        <p class="lede">You pay per enriched candidate, with monthly volume tiers — the more you run, the lower the per-candidate rate. We'll size a quote to your volume and buyer type.</p>
        <ul class="ticks">
          <li>Volume-based monthly tiers</li>
          <li>No per-seat setup fee</li>
          <li>Bulk upload today — API on the roadmap</li>
          <li>Paid pilots, fully credited against your first contract</li>
          <li>The same promise as our consumer product — nothing made up</li>
        </ul>
        <a class="btn btn-primary btn-lg" href="mailto:support@adaptiveresume.com?subject=AdaptiveResume%20—%20commercial%20inquiry">Request a quote →</a>
      </div>
      <div class="card tiers">
        <h3>Volume tiers</h3>
        <p class="muted">Per-candidate rate steps down as monthly volume rises.</p>
        <ul class="tierlist">
          <li><span>Starter volume</span><span class="q">quote</span></li>
          <li><span>Growing volume</span><span class="q">quote</span></li>
          <li><span>High volume</span><span class="q">quote</span></li>
          <li><span>Enterprise / channel</span><span class="q">quote</span></li>
        </ul>
        <p class="muted small">Exact tiers and rates are set with you on a short call — sized to your real monthly volume.</p>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="section">
    <div class="container cta-band">
      <h2>Start with a paid pilot on your own candidates.</h2>
      <p class="lede">Bring a real batch. Pilots run at standard rates and are fully credited against your first contract — so you see the enrichment and the integrity flags on your own people, and the pilot money is never spent twice.</p>
      <a class="btn btn-primary btn-lg" href="#quote">Request a pilot quote</a>
    </div>
  </section>

  <style>
    .hero { padding: 58px 0 40px; background:
      radial-gradient(1100px 460px at 72% -12%, #d8e5fa, transparent 70%),
      radial-gradient(760px 380px at 4% 112%, #fdf0dc, transparent 62%),
      var(--bg); }
    .hero-grid { display: grid; gap: 34px; align-items: center; }
    @media (min-width: 920px) { .hero-grid { grid-template-columns: 1.1fr 0.9fr; } }
    .hero-grid img { border-radius: var(--radius); box-shadow: var(--shadow); width: 100%; height: auto; }
    .cta-row { display: flex; flex-wrap: wrap; gap: 12px; margin: 22px 0 12px; }
    .small { font-size: .85rem; }

    .chips { list-style: none; display: flex; flex-wrap: wrap; gap: 10px; padding: 0; margin: 8px 0 0; }
    .chip { background: var(--card); border: 1px solid var(--line); border-radius: 999px; padding: 9px 16px; font-weight: 600; color: var(--ink-soft); box-shadow: var(--shadow); }

    .steps .card { position: relative; padding-top: 30px; }
    .steps .card:hover { box-shadow: var(--shadow-lg); }
    .step-n { position: absolute; top: -16px; left: 22px; width: 34px; height: 34px; display: grid; place-items: center; border-radius: 9px; background: linear-gradient(135deg, var(--accent-strong), #d97706); color: #16202b; font-weight: 800; box-shadow: 0 4px 12px rgba(217,119,6,.3); }

    .ticks { list-style: none; padding: 0; margin: 14px 0 18px; }
    .ticks li { padding-left: 26px; position: relative; margin-bottom: 9px; color: var(--ink-soft); }
    .ticks li::before { content: "✓"; position: absolute; left: 0; color: var(--true); font-weight: 800; }

    .quote-grid { display: grid; gap: 28px; align-items: start; }
    @media (min-width: 880px) { .quote-grid { grid-template-columns: 1.2fr 0.8fr; } }
    .tiers .tierlist { list-style: none; padding: 0; margin: 14px 0; }
    .tiers .tierlist li { display: flex; justify-content: space-between; padding: 12px 0; border-bottom: 1px solid var(--line); font-weight: 600; color: var(--ink-soft); }
    .tiers .q { color: var(--primary); font-weight: 700; }

    .cta-band { text-align: center; max-width: 720px; }
    .cta-band .lede { margin: 0 auto 18px; max-width: 54ch; }
  </style>
</Base>
